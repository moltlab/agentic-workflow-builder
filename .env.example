# =============================================================================
# Agentic Workflow Builder - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Required ---
OPENAI_API_KEY=sk-your-openai-api-key-here
MCP_SERVER_URL=http://mcp-server:8001/mcp
DATABASE_URL=postgresql://postgres:postgres@db:5432/agentic_ai_db

# --- Application ---
APP_PORT=8000
PYTHONPATH=/app

# --- Reverse Proxy (Nginx) ---
# Set root_path so Swagger docs work at /agentic-workflow-builder/docs
API_ROOT_PATH=/agentic-workflow-builder
# Comma-separated list of allowed frontend origins (or * for all)
CORS_ORIGINS=https://moltlabs.cloud,http://localhost:3000

# --- Database (used by docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentic_ai_db

# --- Security ---
# Required when creating/updating datasources that store encrypted credentials.
# You can use a random 32+ char passphrase or a Fernet key.
DATASOURCE_ENCRYPTION_KEY=change-this-to-a-strong-secret

# --- Optional: Alternative LLM Providers ---
# DEEPSEEK_URL=http://your-deepseek-endpoint/v1
# QWEN_URL=http://your-qwen-endpoint/v1

# --- Optional: OpenTelemetry / Observability ---
# OTLP_ENDPOINT=http://clickhouse:4318/v1/traces
# CLICKHOUSE_HOST=clickhouse
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DATABASE=otel
# CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=

# --- Optional: Media Storage (GCS) ---
# GCS_BUCKET_NAME=your-bucket
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcs-key.json

# --- Optional: RAG ---
# VECTOR_STORE_PATH=.vector_store
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# EMBEDDING_MODEL=text-embedding-ada-002
